# Meta Cloud API
META_PHONE_NUMBER_ID=          # ID del número Business (lo ves en Meta for Developers > WhatsApp > API Setup)
META_BUSINESS_ACCOUNT_ID=      # ID de tu cuenta de WhatsApp Business
META_ACCESS_TOKEN=             # Token de acceso de larga duración (EAAxxxxx...)
META_WEBHOOK_VERIFY_TOKEN=     # Cualquier string secreto que tú elijas para verificar el webhook

# OpenAI
OPENAI_API_KEY=                # sk-proj-xxxxx...

# Google Sheets
GOOGLE_SHEET_ID=               # El ID del Google Sheet (está en la URL: /d/ESTE_ID/edit)
GOOGLE_SERVICE_ACCOUNT_EMAIL=  # bot@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=            # "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Número del dueño (para escalamientos y resumen diario)
# Formato: +1809XXXXXXX (sin el prefijo "whatsapp:")
OWNER_WHATSAPP_NUMBER=

# Nombre de la tienda (aparece en mensajes del bot)
STORE_NAME=Tropicland

# Vercel Cron Jobs (genera un string aleatorio, ej: openssl rand -hex 32)
CRON_SECRET=

# Servidor
PORT=3000
NODE_ENV=development
